# RELPER XML Feed
RELPER_FEED_URL=https://your-relper-feed-url.com/feed.xml
RELPER_API_KEY=your_relper_api_key

# Webflow CMS
WEBFLOW_API_TOKEN=your_webflow_api_token
WEBFLOW_COLLECTION_ID=your_collection_id
WEBFLOW_SITE_ID=your_site_id  # required — resolves sr/en/ru cmsLocaleIds via sites:read

# Optional fallback if API token lacks sites:read scope.
# Run: node scripts/fetch-locale-ids.mjs  (needs sites:read once)
# WEBFLOW_CMS_LOCALE_SR=
# WEBFLOW_CMS_LOCALE_EN=
# WEBFLOW_CMS_LOCALE_RU=

# Mapbox (Scenario B — geocoding)
MAPBOX_TOKEN=your_mapbox_token

# Azure AI Translator (EN/RU name + description)
AZURE_TRANSLATOR_KEY=your_azure_translator_key
AZURE_TRANSLATOR_REGION=northeurope
TRANSLATE_ENABLED=true

# Sync config
SYNC_INTERVAL_MINUTES=30
DRY_RUN=false
